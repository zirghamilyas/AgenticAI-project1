PORT=3000
NODE_ENV=development

# Weaviate (Docker Compose defaults)
WEAVIATE_HTTP_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051

# Optional: scripts/fetch-all-weaviate-objects.ts
# WEAVIATE_TENANT_ID=tenant-demo
# WEAVIATE_FETCH_LIMIT=10000

# Optional: Google Gemini via LangChain (leave unset for graceful template-only mode)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Tests / scripts: use mock LLM (production ignores this)
LLM_PROVIDER=gemini
